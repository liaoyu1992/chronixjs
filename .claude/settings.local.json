      "Bash(cp \"C:/Users/liaoyu/work/cluade-smart/.claude/memory/vector_store.py\" \"C:/Users/liaoyu/work/chronixjs/.claude/memory/vector_store.py\")",
      "Bash(cp \"C:/Users/liaoyu/work/cluade-smart/.claude/bin/promote-to-team.py\" \"C:/Users/liaoyu/work/chronixjs/.claude/bin/promote-to-team.py\")",
      "Bash(cp \"C:/Users/liaoyu/work/cluade-smart/.claude/bin/observations_rotate.py\" \"C:/Users/liaoyu/work/chronixjs/.claude/bin/observations_rotate.py\")",
      "Bash(cp \"C:/Users/liaoyu/work/cluade-smart/.claude/bin/consolidate_instincts.py\" \"C:/Users/liaoyu/work/chronixjs/.claude/bin/consolidate_instincts.py\")",
