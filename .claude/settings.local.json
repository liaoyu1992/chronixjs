      "Bash(bash -c \"echo '{\\\\\"tool_name\\\\\":\\\\\"Bash\\\\\"}' | bash .claude/hooks/observe.sh pre\")",
      "Bash(echo \"Exit: $?\")",
      "Bash(bash -x *)",
      "Bash(bash .claude/hooks/observe.sh pre)",
      "Bash(echo \"Exit with empty stdin: $?\")",
      "Bash(bash .claude/hooks/observe.sh *)",
      "Bash(bash .claude/hooks/stop.sh)",
      "Bash(bash .claude/hooks/session-inject.sh)",
