{
  "permissions": {
    "allow": [
      "mcp__zai-mcp-server__diagnose_error_screenshot",
      "mcp__zai-mcp-server__analyze_image"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/observe.sh pre"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/observe.sh post"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "bash .claude/hooks/session-inject.sh"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash .claude/hooks/stop.sh"
      }
    ]
  }
}
