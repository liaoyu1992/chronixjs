{
  "name": "@chronixjs/gantt-vue2",
  "version": "0.1.0",
  "description": "Vue 2.7 adapter for @chronixjs/gantt — composable + component wrappers over the framework-agnostic core",
  "license": "MIT",
  "author": "liaoyu1992",
  "homepage": "https://github.com/liaoyu1992/chronixjs/tree/master/adapters/vue2#readme",
  "bugs": {
    "url": "https://github.com/liaoyu1992/chronixjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liaoyu1992/chronixjs.git",
    "directory": "adapters/vue2"
  },
  "keywords": [
    "gantt",
    "timeline",
    "scheduler",
    "vue",
    "vue2",
    "composable",
    "adapter",
    "component-library"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@chronixjs/gantt": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^2.7.0"
  },
  "devDependencies": {
    "@chronixjs/eslint-config": "workspace:*",
    "@types/node": "^26.0.0",
    "@vue/test-utils": "^1.3.6",
    "happy-dom": "^20.10.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "vue": "^2.7.16",
    "vue-template-compiler": "^2.7.16"
  }
}
