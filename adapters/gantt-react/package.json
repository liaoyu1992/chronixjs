{
  "name": "@chronixjs/gantt-react",
  "version": "0.1.0",
  "description": "React 18 adapter for @chronixjs/gantt — hooks + component wrappers over the framework-agnostic core",
  "license": "MIT",
  "author": "liaoyu1992",
  "homepage": "https://github.com/liaoyu1992/chronixjs/tree/master/adapters/react#readme",
  "bugs": {
    "url": "https://github.com/liaoyu1992/chronixjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liaoyu1992/chronixjs.git",
    "directory": "adapters/react"
  },
  "keywords": [
    "gantt",
    "timeline",
    "scheduler",
    "react",
    "react18",
    "hooks",
    "adapter",
    "component-library"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@chronixjs/gantt": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@chronixjs/eslint-config": "workspace:*",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
