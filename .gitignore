# .claude — keep settings, skills, memory, workflows in git for portability
# only ignore transient / machine-local dirs
.claude/worktrees/
.claude/scheduled_tasks.json
.claude/*.jsonl
.history

# claude-smart self-evolution system — runtime + personal data stays local.
# System code (.claude/bin, .claude/hooks, .claude/memory/*.py) and team
# instincts (.claude/homunculus/instincts/team/) ARE tracked for portability.
.claude/data/
.claude/homunculus/instincts/personal/
.claude/homunculus/instincts/promote-candidates.md
.claude/rules/auto-evolved.md
.claude/rules/injected-memory.md
.claude/memory/raw/
.claude/settings.local.json

# qoder self-evolution system — runtime + personal data stays local.
# System code (.qoder/bin, .qoder/hooks, .qoder/memory/*.py) and team
# instincts (.qoder/homunculus/instincts/team/) ARE tracked for portability.
.qoder/data/
.qoder/config/ai-gateway.env
.qoder/homunculus/instincts/personal/
.qoder/homunculus/instincts/promote-candidates.md
.qoder/rules/auto-evolved.md
.qoder/rules/injected-memory.md
.qoder/memory/raw/
.qoder/settings.local.json

# Python bytecode (self-evolution scripts)
__pycache__/
*.py[cod]

# Docs
docs/.vitepress/dist
docs/.vitepress/cache

# golden-runner scratch — one-off diagnostic probes + screenshot output.
# Underscore prefix (_probe*.mjs, _cap_cmp.mjs, _shots/) marks throwaway
# local diagnostics; tracked scripts use run-*/verify-phase-* names.
tooling/golden-runner/scripts/_*
