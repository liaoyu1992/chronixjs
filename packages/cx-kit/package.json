{
  "name": "@chronixjs/cx-kit",
  "version": "0.1.0",
  "description": "Headless UI primitives (virtual list / slider / range / color picker / autocomplete) used by chronix adapters; framework-agnostic core",
  "license": "MIT",
  "author": "liaoyu1992",
  "homepage": "https://github.com/liaoyu1992/chronixjs/tree/master/packages/cx-kit#readme",
  "bugs": {
    "url": "https://github.com/liaoyu1992/chronixjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liaoyu1992/chronixjs.git",
    "directory": "packages/cx-kit"
  },
  "keywords": [
    "headless",
    "ui",
    "virtual-list",
    "slider",
    "color-picker",
    "autocomplete",
    "component-library"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@chronixjs/eslint-config": "workspace:*",
    "@types/node": "^26.1.0",
    "happy-dom": "^20.10.6",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
