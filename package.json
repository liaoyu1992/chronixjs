{
  "name": "chronix",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Chronix component library monorepo",
  "license": "MIT",
  "author": "liaoyu1992",
  "homepage": "https://github.com/liaoyu1992/chronixjs#readme",
  "bugs": {
    "url": "https://github.com/liaoyu1992/chronixjs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liaoyu1992/chronixjs.git"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,vue,json,md,css,scss,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,vue,json,md,css,scss,html}\"",
    "stylelint": "stylelint \"**/*.{css,scss,vue}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "clean": "turbo run clean && rimraf node_modules",
    "ci-check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "docs:dev": "pnpm --filter @chronixjs/docs docs:dev",
    "docs:build": "pnpm --filter @chronixjs/docs docs:build",
    "docs:preview": "pnpm --filter @chronixjs/docs docs:preview",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@chronixjs/eslint-config": "workspace:*",
    "@chronixjs/stylelint-config": "workspace:*",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.6",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "stylelint": "^17.14.0",
    "turbo": "^2.10.4",
    "typescript": "^5.6.3"
  }
}
