@chronixjs:registry=https://registry.npmjs.org/
auto-install-peers=true
strict-peer-dependencies=false
shared-workspace-lockfile=true
save-workspace-protocol=rolling
# Phase 31: Vue 2.7 + Vue 3.5 coexist (gantt-vue2 / gantt-vue3 sibling adapters).
# Prevent pnpm from hoisting either vue version to `.pnpm/node_modules/vue` —
# without this, vue-template-compiler@2.7.16 (pulled in by @vue/test-utils@1.x)
# `require('vue')` walks up from its deep .pnpm path, finds whichever vue
# pnpm hoisted (non-deterministic between Vue 2 / Vue 3), and throws a
# version-mismatch error when the hoist roll lands on Vue 3.
hoist-pattern[]=!vue
public-hoist-pattern[]=!vue
