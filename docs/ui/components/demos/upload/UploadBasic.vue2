<template>
  <div style="max-width: 480px">
    <ChronixUpload
      action="/api/upload"
      :file-list="fileList"
      accept="image/*"
      @update:file-list="fileList = $event"
    />
    <p style="font-size: 13px; color: #888; margin-top: 8px">Only image files are accepted.</p>
  </div>
</template>

<script>
import { ChronixUpload } from '@chronixjs/ui-vue2';
export default {
  components: { ChronixUpload },
  data() {
    return { fileList: [] };
  },
};
</script>
